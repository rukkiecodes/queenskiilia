# QueenSkiilia Web — environment template. Copy to .env and fill in.
# Nuxt auto-maps NUXT_PUBLIC_* -> runtimeConfig.public.*, NUXT_* -> runtimeConfig.*

# GraphQL gateway + auth BFF target (main-server)
NUXT_PUBLIC_API_URL=https://queenskilla-mainserver.vercel.app

# Cloudinary (unsigned browser upload)
NUXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NUXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Paystack public key (web uses redirect/popup; secret key stays in paystack-service)
NUXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Internal service secret (only if a Nuxt server route needs to call internal backend endpoints)
NUXT_INTERNAL_SECRET=
