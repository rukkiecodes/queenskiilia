{
  "name": "queenskilla-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "development": "eas build --platform android --profile development --clear-cache",
    "production": "eas build --platform android --profile production --clear-cache",
    "preview": "eas build --platform android --profile preview --clear-cache",
    "update:development": "eas update --branch development --auto",
    "update:preview": "eas update --branch preview --auto",
    "update:production": "eas update --branch production --auto"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.99.0",
    "date-fns": "^4.1.0",
    "expo": "^55.0.19",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.32",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6",
