{
  "expo": {
    "name": "queenskilla-mobile",
    "slug": "queenskilla-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "queenskillamobile",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rukkiecodes2.queenskillamobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "QueenSkiilia uses your camera to verify your identity (face match) and to take photos of your ID.",
          "microphonePermission": "QueenSkiilia does not record audio, but the camera module requires this entry to be present.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QueenSkiilia accesses your photo library so you can upload an avatar or a photo of your ID document.",
          "cameraPermission": "QueenSkiilia uses your camera to take a photo of your ID document or your face for verification."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3d8d8ca4-b1e6-4e2d-b685-2d80eb3646c6"
      }
    }
  }
}
