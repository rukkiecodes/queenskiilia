# Copy to .env.local for local dev, and set the same vars in Vercel for prod.

# Public site URL (used for canonical, OpenGraph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://queenskilla.app

# Deployed legal site (privacy.html / terms.html live here)
NEXT_PUBLIC_LEGAL_URL=https://queenskilla-legal.vercel.app

# ── Supabase / Postgres (server-side only — never expose to the client) ──
# Mirror these from main-server/.env. Either supply a single connection string…
# SUPABASE_CONNECTION_STRING=postgresql://user:password@host:5432/postgres

# …or the discrete pool variables (same names used by database/*-setup.ts):
SUPABASE_POOL_HOST=
SUPABASE_POOL_PORT=5432
SUPABASE_POOL_DATABASE=postgres
SUPABASE_POOL_USER=
SUPABASE_DB_PASSWORD=
